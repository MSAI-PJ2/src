# ???뚯씪??.env濡?蹂듭궗??梨꾩슦怨? .env???덈? 而ㅻ컠 湲덉?.
# ?ㅻ뒗 寃뚯씠?몄썾???쒕쾭)?먯꽌留?蹂댁쑀?섍퀬, ?꾨줎?몄뿏??釉뚮씪?곗????덈? ?몄텧 湲덉?.

LLM_PROVIDER=local   # local(?뚯뒪?? 臾대즺 Nemotron) | azure(?쒕퉬?? 怨쇨툑)

# --- local (vLLM / Nemotron) ---
LOCAL_LLM_BASE_URL=http://192.168.1.155:8002/v1
LOCAL_LLM_MODEL=nemotron-3-super-no-think
LOCAL_LLM_API_KEY=dummy

# --- azure openai (production) ---
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
AZURE_OPENAI_API_KEY=<your-key>
AZURE_OPENAI_DEPLOYMENT=<your-deployment-name>

AZURE_OPENAI_MAX_COMPLETION_TOKENS=4096
AZURE_OPENAI_TOP_P=1.0
AZURE_OPENAI_FREQUENCY_PENALTY=0.0
AZURE_OPENAI_PRESENCE_PENALTY=0.0

# --- azure model router (LLM_PROVIDER=azure_model_router) ---
# ?먮룞 紐⑤뜽?좏깮 ?쇱슦?? 怨쇨툑=?좏깮???섏쐞紐⑤뜽 ?좏겙 + ?낅젰?좏겙 留덊겕???쇱슦??臾대즺 ?꾨떂).
# 由ъ쟾: East US 2 / Sweden Central 留? 諛고룷紐낅쭔 ?ㅻⅤ怨?endpoint/key/api_version? ??azure? 怨듭쑀.
# 鍮꾩슦硫?AZURE_OPENAI_DEPLOYMENT濡??대갚.
AZURE_OPENAI_ROUTER_DEPLOYMENT=<your-model-router-deployment>

# ===================== ?덉쟾 寃뚯씠??(Azure AI Content Safety) =====================
# safety_check ?덉씤. true硫??ㅽ샇異? 誘몄꽕???μ븷 ???ㅼ썙???대갚(fail-safe). F0 臾대즺(??5K).
CONTENT_SAFETY_ENABLED=false
CONTENT_SAFETY_ENDPOINT=https://<your-cs>.cognitiveservices.azure.com/
CONTENT_SAFETY_KEY=<your-key>
CONTENT_SAFETY_THRESHOLD=2   # severity 0/2/4/6 以?李⑤떒 湲곗? (?쒓뎅???꾧린臾몄? 蹂댄넻 2)

# ===================== RAG retrieve ?덉씤 =====================
RETRIEVE_PROVIDER=local   # local(?뚯뒪?? 臾대즺 ?몃찓紐⑤━) | azure(?쒕퉬?? Azure AI Search)

# 肄뷀띁??荑쇰━???숈씪?섍쾶 ?곕뒗 ?꾨쿋??紐⑤뜽(?묒そ provider 怨듯넻 ??踰≫꽣 ?명솚???꾩닔).
# 湲곕낯: ?ㅺ뎅??MiniLM(384d). ?쒓뎅???덉쭏???먰븯硫?jhgan/ko-sroberta-multitask(768d).
RETRIEVE_EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# --- local (?몃찓紐⑤━ 肄붿궗?? ---
# JSONL: 以꾨떦 {"id":..., "content":"...", "metadata":{...}}  (?곸슜媛???쒓뎅??43嫄??꾪꽣??
RETRIEVE_LOCAL_CORPUS=./data/psych_corpus_filtered.jsonl

# --- azure ai search (production) ---
# Free ?곗뼱: 援щ룆??1?쒕퉬??50MB/怨듭쑀/?ㅼ??쇰텋媛/managed identity 誘몄????????몄쬆 怨좎젙.
AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
AZURE_SEARCH_API_KEY=<query-or-admin-key>
AZURE_SEARCH_INDEX=<your-index-name>
AZURE_SEARCH_VECTOR_FIELD=contentVector
AZURE_SEARCH_CONTENT_FIELD=content
AZURE_SEARCH_ID_FIELD=id
# ?쒕㎤????빱??由ъ쟾 ?섏〈(Free ?먯꽌 ?쇰? 由ъ쟾留?吏??. 誘몄???由ъ쟾?대㈃ 鍮꾩썙?먭린(=hybrid only).
AZURE_SEARCH_SEMANTIC_CONFIG=


# Azure AI Speech - STT/TTS provider
SPEECH_PROVIDER=azure
AZURE_SPEECH_ENDPOINT=https://koreacentral.api.cognitive.microsoft.com/
AZURE_SPEECH_REGION=koreacentral
AZURE_SPEECH_KEY=<set-in-azure-secret-or-local-env>
AZURE_SPEECH_LANGUAGE=ko-KR
AZURE_SPEECH_VOICE=ko-KR-SunHiNeural
AZURE_SPEECH_OUTPUT_FORMAT=audio-16khz-32kbitrate-mono-mp3
AZURE_SPEECH_MAX_CHARS=2500
