# Copy this file to .env and fill values for local development only.
# Do not commit .env. Do not expose server-side keys to frontend/browser code.

# ===================== LLM provider =====================
# local: local/OpenAI-compatible test server such as vLLM/Nemotron
# azure: Azure OpenAI Chat Completions
# azure_responses: Azure OpenAI Responses API path for Foundry/GPT-5 style deployments
# azure_model_router: Azure model router deployment
LLM_PROVIDER=local

# --- local LLM (vLLM / Nemotron) ---
LOCAL_LLM_BASE_URL=http://192.168.1.155:8002/v1
LOCAL_LLM_MODEL=nemotron-3-super-no-think
LOCAL_LLM_API_KEY=dummy

# --- Azure OpenAI / Azure AI Foundry ---
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
AZURE_OPENAI_API_KEY=<your-key>
AZURE_OPENAI_DEPLOYMENT=<your-deployment-name>
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Default per-response token cap. Also used as the default server-side upper
# bound for request-level llm.max_completion_tokens unless the *_LIMIT value is set.
AZURE_OPENAI_MAX_COMPLETION_TOKENS=1200
AZURE_OPENAI_MAX_COMPLETION_TOKENS_LIMIT=12000
AZURE_OPENAI_TOP_P=1.0
AZURE_OPENAI_FREQUENCY_PENALTY=0.0
AZURE_OPENAI_PRESENCE_PENALTY=0.0

# --- Azure model router (LLM_PROVIDER=azure_model_router) ---
# Leave empty to fall back to AZURE_OPENAI_DEPLOYMENT.
AZURE_OPENAI_ROUTER_DEPLOYMENT=<your-model-router-deployment>

# ===================== Gateway auth / CORS =====================
# API_KEY_REQUIRED=true protects gateway endpoints with x-api-key.
# Never put API_KEY in frontend code for production.
API_KEY_REQUIRED=true
API_KEY=<gateway-api-key>
ALLOWED_ORIGINS=*

# ===================== Azure AI Content Safety =====================
# If enabled and configured, the gateway checks user input before LLM generation.
# If Azure Content Safety fails, keyword fallback still handles obvious crisis text.
CONTENT_SAFETY_ENABLED=false
CONTENT_SAFETY_ENDPOINT=https://<your-cs>.cognitiveservices.azure.com/
CONTENT_SAFETY_KEY=<your-key>
# Azure severity values are commonly 0/2/4/6. 2 is a conservative test threshold.
CONTENT_SAFETY_THRESHOLD=2
CONTENT_SAFETY_TIMEOUT=8

# ===================== RAG / retrieve provider =====================
# local: offline/local stub retrieval for development
# azure: Azure AI Search retrieval
RETRIEVE_PROVIDER=local

# Embedding model used by older/local retrieval paths if enabled.
RETRIEVE_EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# --- local corpus ---
# JSONL line format: {"id": "...", "content": "...", "metadata": {...}}
RETRIEVE_LOCAL_CORPUS=./data/psych_corpus_filtered.jsonl

# --- Azure AI Search ---
AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
AZURE_SEARCH_API_KEY=<query-or-admin-key>
AZURE_SEARCH_INDEX=<your-index-name>
AZURE_SEARCH_VECTOR_FIELD=contentVector
AZURE_SEARCH_CONTENT_FIELD=content
AZURE_SEARCH_ID_FIELD=id
# Optional semantic configuration. Leave empty for keyword/hybrid-only search.
AZURE_SEARCH_SEMANTIC_CONFIG=
AZURE_SEARCH_SELECT_FIELDS=

# ===================== Azure AI Speech - STT/TTS =====================
SPEECH_PROVIDER=azure
AZURE_SPEECH_ENDPOINT=https://koreacentral.api.cognitive.microsoft.com/
AZURE_SPEECH_REGION=koreacentral
AZURE_SPEECH_KEY=<set-in-azure-secret-or-local-env>
AZURE_SPEECH_LANGUAGE=ko-KR
AZURE_SPEECH_VOICE=ko-KR-SunHiNeural
AZURE_SPEECH_OUTPUT_FORMAT=audio-16khz-32kbitrate-mono-mp3
AZURE_SPEECH_MAX_CHARS=2500

# Azure Speech STT short-audio REST settings
AZURE_SPEECH_STT_TIMEOUT=45
AZURE_SPEECH_STT_MAX_BYTES=10485760
# Optional override. Default is:
# https://<region>.stt.speech.microsoft.com/speech/recognition/conversation/cognitiveservices/v1
AZURE_SPEECH_STT_ENDPOINT=

# ===================== Session settings =====================
# Current sessions are anonymous in-memory smoke-test sessions.
# Use Cosmos DB/Redis/etc. before relying on this with multiple replicas.
SESSION_TTL_SECONDS=3600
SESSION_MAX_SESSIONS=1000
SESSION_MAX_TURNS=20
SESSION_CONTEXT_TURNS=6

# ===================== Common HTTP settings =====================
REQUEST_TIMEOUT_SECONDS=60

