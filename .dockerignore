# Default deny: keep Docker/ACR build context small and stable.
# The repository root may contain unrelated team folders, but the api-gateway
# image only needs the whitelisted gateway-container tree below.
*

# Files Docker may need from the build context.
!.dockerignore

# api-gateway image inputs. Do not remove unless Dockerfile COPY paths change.
!gateway-container/
!gateway-container/api-gateway/
!gateway-container/api-gateway/**
!gateway-container/common/
!gateway-container/common/**
!gateway-container/retrieve/
!gateway-container/retrieve/**

# Always exclude generated Python cache even inside whitelisted folders.
**/__pycache__/
**/*.pyc
