# .env 로 복사해 로컬 개발에서만 사용. 커밋 금지, 프론트 코드에 키 노출 금지.
# 운영(ACA)의 실제 키는 secretref 로 주입한다.

# --- 분류기 (내부 cogdist Container App) ---
KLUE_API_URL=http://cogdist:8000

# --- 인증 / CORS ---
API_KEY_REQUIRED=true
API_KEY=<gateway-api-key>
ALLOWED_ORIGINS=*
# Microsoft Entra External ID 로그인 — 코드는 이미 구현됨(api/v1.py 구획 2).
# 아래 3개(TENANT_ID + CLIENT_ID, 또는 ISSUER + CLIENT_ID)를 채우고
# AUTH_MODE=entra 로 바꾸면 즉시 JWT 검증 게이트가 켜진다. ISSUER 생략 시 TENANT_ID 로 유도.
AUTH_MODE=api_key
#AUTH_MODE=entra
#ENTRA_TENANT_ID=<tenant-guid>
#ENTRA_CLIENT_ID=<api-app-registration-client-id>
#ENTRA_ISSUER=https://<tenant-guid>.ciamlogin.com/<tenant-guid>/v2.0

# --- Azure OpenAI (LLM) ---
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
AZURE_OPENAI_API_KEY=<your-key>
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_MAX_COMPLETION_TOKENS=1200
AZURE_OPENAI_MAX_COMPLETION_TOKENS_LIMIT=12000

# --- Azure AI Content Safety ---
CONTENT_SAFETY_ENABLED=false
CONTENT_SAFETY_ENDPOINT=https://<your-cs>.cognitiveservices.azure.com/
CONTENT_SAFETY_KEY=<your-key>
CONTENT_SAFETY_THRESHOLD=2

# --- 튜닝 노브 (기본값 = 현행 동작. 스위프 테스트 후 조정) ---
# 라벨 일치 문서 가산점: 크기 / 발동 최소확신 / 판정 기준(score|selected|either)
# multi_label 모델(sigmoid, 점수 낮게 깔림)로 전환 시 RERANK_BIAS_SOURCE=selected 권장
RERANK_BIAS_WEIGHT=0.3
RERANK_BIAS_MIN_CONFIDENCE=0.5
RERANK_BIAS_SOURCE=score
# 왜곡 라벨 저확신 강등 하한 (0=꺼짐): 미만이면 clarify 정책(low_confidence_clarify)으로
POLICY_MIN_CONFIDENCE=0.0

# --- Azure AI Search (RAG) ---
AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
AZURE_SEARCH_API_KEY=<query-or-admin-key>
AZURE_SEARCH_INDEX=<your-index-name>
AZURE_SEARCH_CONTENT_FIELD=content
AZURE_SEARCH_ID_FIELD=id
AZURE_SEARCH_SEMANTIC_CONFIG=

# --- Azure Document Intelligence (채팅 캡쳐 이미지 OCR) ---
# 원본 파이프라인: 리포 루트 di/ (팀원 작업물). 리소스: team3-doc-intel (Free F0)
DOCINTEL_ENDPOINT=https://<your-doc-intel-resource>.cognitiveservices.azure.com/
DOCINTEL_KEY=<set-in-azure-secret-or-local-env>

# --- Azure Speech (STT/TTS) ---
AZURE_SPEECH_KEY=<set-in-azure-secret-or-local-env>
AZURE_SPEECH_REGION=koreacentral
AZURE_SPEECH_DEFAULT_VOICE=ko-KR-SunHiNeural

# --- 세션 저장소: memory(개발/테스트) | cosmos(운영) ---
SESSION_REPOSITORY=memory
SESSION_TTL_SECONDS=3600
SESSION_MAX_TURNS=20
SESSION_CONTEXT_TURNS=6
COSMOS_ENDPOINT=https://<your-cosmos-account>.documents.azure.com:443/
COSMOS_KEY=<set-in-azure-secret-or-local-env>
COSMOS_DATABASE=<your-database-name>
COSMOS_CONTAINER=<your-container-name>
#COSMOS_CONNECTION_STRING=

# --- 관측 (설정 시에만 App Insights 활성화) ---
#APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...
